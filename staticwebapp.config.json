{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/*.{css,js,mjs,png,jpg,jpeg,gif,svg,ico,json,txt,map}"
    ]
  },
  "platform": {
    "apiRuntime": "dotnet-isolated:9.0"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "no-referrer",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()"
  }
}
